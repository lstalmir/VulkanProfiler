- Type: VkQueueFlags
  Serialize: GetQueueFlagNames
  Deserialize: GetQueueFlags
  Bits:
    VK_QUEUE_GRAPHICS_BIT: "Graphics"
    VK_QUEUE_COMPUTE_BIT: "Compute"
    VK_QUEUE_TRANSFER_BIT: "Transfer"
    VK_QUEUE_SPARSE_BINDING_BIT: "Sparse binding"
    VK_QUEUE_PROTECTED_BIT: "Protected"
    VK_QUEUE_VIDEO_DECODE_BIT_KHR: "Video decode"
    VK_QUEUE_VIDEO_ENCODE_BIT_KHR: "Video encode"
    VK_QUEUE_OPTICAL_FLOW_BIT_NV: "Optical flow"
    VK_QUEUE_DATA_GRAPH_BIT_ARM: "Data graph"

- Type: VkShaderStageFlagBits
  Serialize: GetShaderStageName
  Deserialize: GetShaderStage
  Values:
    VK_SHADER_STAGE_VERTEX_BIT: "Vertex shader"
    VK_SHADER_STAGE_TESSELLATION_CONTROL_BIT: "Tessellation control shader"
    VK_SHADER_STAGE_TESSELLATION_EVALUATION_BIT: "Tessellation evaluation shader"
    VK_SHADER_STAGE_GEOMETRY_BIT: "Geometry shader"
    VK_SHADER_STAGE_FRAGMENT_BIT: "Fragment shader"
    VK_SHADER_STAGE_COMPUTE_BIT: "Compute shader"
    VK_SHADER_STAGE_TASK_BIT_EXT: "Task shader"
    VK_SHADER_STAGE_MESH_BIT_EXT: "Mesh shader"
    VK_SHADER_STAGE_RAYGEN_BIT_KHR: "Ray generation shader"
    VK_SHADER_STAGE_ANY_HIT_BIT_KHR: "Ray any-hit shader"
    VK_SHADER_STAGE_CLOSEST_HIT_BIT_KHR: "Ray closest-hit shader"
    VK_SHADER_STAGE_MISS_BIT_KHR: "Ray miss shader"
    VK_SHADER_STAGE_INTERSECTION_BIT_KHR: "Ray intersection shader"
    VK_SHADER_STAGE_CALLABLE_BIT_KHR: "Callable shader"
    VK_SHADER_STAGE_SUBPASS_SHADING_BIT_HUAWEI: "Subpass shading shader"
    VK_SHADER_STAGE_CLUSTER_CULLING_BIT_HUAWEI: "Cluster culling shader"
  Ignore:
    - VK_SHADER_STAGE_ALL
    - VK_SHADER_STAGE_ALL_GRAPHICS

- Type: VkShaderStageFlagBits
  Serialize: GetShortShaderStageName
  Values:
    VK_SHADER_STAGE_VERTEX_BIT: "VS"
    VK_SHADER_STAGE_TESSELLATION_CONTROL_BIT: "TCS"
    VK_SHADER_STAGE_TESSELLATION_EVALUATION_BIT: "TES"
    VK_SHADER_STAGE_GEOMETRY_BIT: "GS"
    VK_SHADER_STAGE_FRAGMENT_BIT: "PS"
    VK_SHADER_STAGE_COMPUTE_BIT: "CS"
    VK_SHADER_STAGE_TASK_BIT_EXT: "Task"
    VK_SHADER_STAGE_MESH_BIT_EXT: "Mesh"
    VK_SHADER_STAGE_RAYGEN_BIT_KHR: "Raygen"
    VK_SHADER_STAGE_ANY_HIT_BIT_KHR: "Any-hit"
    VK_SHADER_STAGE_CLOSEST_HIT_BIT_KHR: "Closest-hit"
    VK_SHADER_STAGE_MISS_BIT_KHR: "Miss"
    VK_SHADER_STAGE_INTERSECTION_BIT_KHR: "Intersection"
    VK_SHADER_STAGE_CALLABLE_BIT_KHR: "Callable"
    VK_SHADER_STAGE_SUBPASS_SHADING_BIT_HUAWEI: "SSS"
    VK_SHADER_STAGE_CLUSTER_CULLING_BIT_HUAWEI: "CCS"
  Ignore:
    - VK_SHADER_STAGE_ALL
    - VK_SHADER_STAGE_ALL_GRAPHICS

- Type: VkRayTracingShaderGroupTypeKHR
  Serialize: GetShaderGroupTypeName
  Deserialize: GetShaderGroupType
  Values:
    VK_RAY_TRACING_SHADER_GROUP_TYPE_GENERAL_KHR: "General"
    VK_RAY_TRACING_SHADER_GROUP_TYPE_TRIANGLES_HIT_GROUP_KHR: "Triangles"
    VK_RAY_TRACING_SHADER_GROUP_TYPE_PROCEDURAL_HIT_GROUP_KHR: "Procedural"

